{
  "manifest_version": 3,
  "key": "",
  "name": "Nenya",
  "version": "1.54.0",
  "description": "",
  "icons": {
    "16": "assets/icons/icon-16x16.png",
    "32": "assets/icons/icon-32x32.png",
    "48": "assets/icons/icon-48x48.png",
    "128": "assets/icons/icon-128x128.png"
  },
  "action": {
    "default_title": "Nenya",
    "default_icon": {
      "16": "assets/icons/icon-16x16.png",
      "32": "assets/icons/icon-32x32.png",
      "48": "assets/icons/icon-48x48.png"
    },
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "src/home/index.html"
  },
  "options_page": "src/options/index.html",
  "permissions": [
    "bookmarks",
    "storage",
    "tabs",
    "tabGroups",
    "notifications",
    "contextMenus",
    "alarms",
    "scripting",
    "activeTab",
    "clipboardWrite",
    "clipboardRead",
    "declarativeNetRequest",
    "downloads",
    "tabCapture",
    "desktopCapture",
    "system.display",
    "offscreen"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://oh-auth.vercel.app/*"
    ]
  },
  "host_permissions": [
    "https://api.raindrop.io/*",
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/libs/*",
        "src/contentScript/epicker-ui.html",
        "src/contentScript/epicker-ui.js",
        "src/contentScript/emoji-picker.js",
        "src/contentScript/emoji-picker-ui.html",
        "src/contentScript/emoji-picker-ui.js",
        "src/recording/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/libs/darkreader.js",
        "src/contentScript/darkMode.js",
        "src/contentScript/bright-mode.js",
        "src/contentScript/block-elements.js",
        "src/contentScript/custom-js-css.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/contentScript/video-controller.js",
        "src/contentScript/highlight-text.js",
        "src/contentScript/auto-google-login.js"
      ],
      "css": [
        "src/contentScript/video-controller.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/contentScript/clipboard-monitor.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "src/contentScript/youtube-fixes.js"
      ],
      "run_at": "document_start"
    }
  ],
  "commands": {
    "_execute_action": {
      "description": "Open popup"
    },
    "bookmarks-save-to-unsorted": {
      "description": "💧 Save to Unsorted"
    },
    "bookmarks-save-to-unsorted-encrypted": {
      "description": "💧 Encrypt & Save to Unsorted"
    },
    "bookmarks-save-clipboard-to-unsorted": {
      "description": "💧 Save clipboard link to Unsorted"
    },
    "copy-title": {
      "description": "📋 Copy Title"
    },
    "copy-title-url": {
      "description": "📋 Copy Title\\nURL"
    },
    "copy-title-dash-url": {
      "description": "📋 Copy Title - URL"
    },
    "copy-markdown-link": {
      "description": "📋 Copy [Title](URL)"
    },
    "copy-screenshot": {
      "description": "📋 Copy Screenshot"
    },
    "pip-quit": {
      "suggested_key": {
        "default": "Alt+Q"
      },
      "description": "🎥 Quit PiP"
    },
    "tabs-activate-left-tab": {
      "description": "🗂️ Activate left tab"
    },
    "tabs-activate-right-tab": {
      "description": "🗂️ Activate right tab"
    },
    "split-screen-arrange": {
      "description": "🖥️ Arrange windows for split screen"
    },
    "window-resize-fullscreen": {
      "description": "🖥️ Resize window to full screen"
    },
    "window-resize-left-half": {
      "description": "🖥️ Resize window to left half"
    },
    "window-resize-right-half": {
      "description": "🖥️ Resize window to right half"
    },
    "window-resize-top-half": {
      "description": "🖥️ Resize window to top half"
    },
    "window-resize-bottom-half": {
      "description": "🖥️ Resize window to bottom half"
    },
    "window-merge-single-tab-windows": {
      "description": "🖥️ Merge single-tab windows"
    },
    "block-element-picker": {
      "description": "🎯 Element Picker"
    },
    "llm-chat-with-llm": {
      "description": "🤖 Chat with LLM"
    },
    "llm-download-markdown": {
      "description": "📥 Download as markdown"
    },
    "emoji-picker-show": {
      "description": "😀 Show Emoji Picker"
    },
    "open-in-popup": {
      "description": "↗️ Open in popup"
    },
    "rename-tab": {
      "description": "🏷️ Rename tab"
    },
    "screen-recording-start": {
      "description": "⏺️ Start screen recording"
    },
    "open-pinned-shortcut-1": {
      "suggested_key": {
        "default": "Alt+Shift+1"
      },
      "description": "📌 Open 1st pinned shortcut in new tab"
    },
    "open-pinned-shortcut-2": {
      "suggested_key": {
        "default": "Alt+Shift+2"
      },
      "description": "📌 Open 2nd pinned shortcut in new tab"
    },
    "open-pinned-shortcut-3": {
      "suggested_key": {
        "default": "Alt+Shift+3"
      },
      "description": "📌 Open 3rd pinned shortcut in new tab"
    },
    "open-pinned-shortcut-4": {
      "suggested_key": {
        "default": "Alt+Shift+4"
      },
      "description": "📌 Open 4th pinned shortcut in new tab"
    },
    "open-pinned-shortcut-5": {
      "suggested_key": {
        "default": "Alt+Shift+5"
      },
      "description": "📌 Open 5th pinned shortcut in new tab"
    }
  }
}
